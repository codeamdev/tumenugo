# ── Build output (se regenera en el builder stage) ────────────────────────────
.next/
out/

# ── Dependencias (se reinstalan con npm ci en deps stage) ─────────────────────
node_modules/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Secrets (NUNCA en la imagen Docker) ──────────────────────────────────────
.env
.env.*
ecosystem.config.js

# ── Docker ────────────────────────────────────────────────────────────────────
Dockerfile*
docker-compose*
.dockerignore

# ── Logs y backups ────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Tests y documentación ────────────────────────────────────────────────────
*.test.ts
*.spec.ts
__tests__/
coverage/
