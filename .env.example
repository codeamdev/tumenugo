# Base domain (without protocol). For local dev use: localhost
# For production: tudominio.com
NEXT_PUBLIC_BASE_DOMAIN=localhost

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/cafeteria

# JWT secrets — generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_hex_64

# Anthropic API key (for PDF menu parsing with LLM — Phase 5)
ANTHROPIC_API_KEY=

# App URL (used in emails, callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
