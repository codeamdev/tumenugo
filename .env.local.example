# ══════════════════════════════════════════════════════════════════════════════
# .env.local.example — Plantilla de secretos para desarrollo
#
# Pasos para un desarrollador nuevo:
#   1. cp .env.local.example .env.local
#   2. Rellena los valores (nunca subas .env.local a git)
#   3. npm run dev:db     ← levanta PostgreSQL local
#   4. npm run db:migrate:public && npm run db:migrate:tenants
#   5. npm run dev
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────────
# Usa las credenciales del docker-compose.dev.yml (postgres/postgres por defecto)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cafeteria

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Genera dos valores distintos con: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Anthropic (opcional) ──────────────────────────────────────────────────────
# Solo si vas a probar la importación de menús desde PDF
ANTHROPIC_API_KEY=
