{
  "name": "cafeteria",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:wifi": "next dev --hostname 0.0.0.0",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate:public": "drizzle-kit generate --config=drizzle.config.ts",
    "db:generate:tenant": "drizzle-kit generate --config=drizzle.tenant.config.ts",
    "db:migrate:public": "tsx scripts/migrate-public.ts",
    "db:migrate:tenants": "tsx scripts/migrate-tenants.ts",
    "db:migrate:tenant": "tsx scripts/migrate-tenants.ts --slug",
    "tenant:provision": "tsx scripts/provision-tenant.ts",
    "tenant:seed-demo": "tsx scripts/seed-demo.ts",
    "tenant:user:create": "tsx scripts/create-tenant-user.ts",
    "tenant:change-password": "tsx scripts/change-tenant-password.ts",
    "superadmin:create": "tsx scripts/create-superadmin.ts",
    "superadmin:change-password": "tsx scripts/change-superadmin-password.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@hookform/resolvers": "^3.9.1",
    "@node-rs/argon2": "^1.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@serwist/next": "^9.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.8",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.11.17",
    "jose": "^5.9.6",
    "lucide-react": "^0.454.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.3",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "serwist": "^9.5.11",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
